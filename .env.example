# Configuraciḃn de la aplicaciḃn
APP_NAME="ReservaF cil"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=reservas_db
DB_USERNAME=root
DB_PASSWORD=

# Seguridad
JWT_SECRET=tu_jwt_secret_aqui
ENCRYPTION_KEY=tu_encryption_key_aqui

# MercadoPago
MP_ACCESS_TOKEN=tu_mp_access_token
MP_PUBLIC_KEY=tu_mp_public_key

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_password

# SMS (Twilio)
TWILIO_SID=tu_twilio_sid
TWILIO_TOKEN=tu_twilio_token
TWILIO_FROM=+1234567890

# WhatsApp
WHATSAPP_TOKEN=tu_whatsapp_token
WHATSAPP_PHONE_ID=tu_phone_id
